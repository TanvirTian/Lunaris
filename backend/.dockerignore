# Dependencies — reinstalled fresh during build via npm ci
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / Secrets — never bake these into images
.env
.env.*
!.env.example

# Git / VCS
.git
.gitignore
.gitattributes

# Logs
*.log
logs/
pids/
*.pid
*.seed
*.pid.lock

# Tests / Coverage / Dev-only
*.test.js
*.spec.js
__tests__/
coverage/
.vitest/
.jest/
cypress/
playwright-report/
test-results/

# Build artifacts
dist/
build/
.tmp/
.cache/
.nyc_output/

# TypeScript
*.tsbuildinfo

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS artifacts
.DS_Store
Thumbs.db

# Docker files — no reason to copy these into the build context
Dockerfile
.dockerignore

# Documentation
# NOTE: do NOT add prisma/migrations here — migrate deploy needs them at runtime
docs/